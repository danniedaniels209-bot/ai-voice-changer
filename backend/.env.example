# Copy to backend/.env to override startup defaults. All variables are
# optional — the values shown here are the built-in defaults.
# Day-to-day preferences (device mode, ffmpeg path, export quality) are
# managed in the app's Settings page instead, not here.

# Server bind address/port
AVC_HOST=127.0.0.1
AVC_PORT=8000

# Origin of the Vite dev server, for CORS
AVC_FRONTEND_ORIGIN=http://localhost:5175

# "auto" = CUDA if available, else CPU. Can be forced to "cpu" or "cuda".
AVC_DEFAULT_DEVICE_MODE=auto

# Upload/import size ceilings (MB)
AVC_MAX_UPLOAD_SIZE_MB=8192
AVC_MAX_MODEL_SIZE_MB=2048

# How many conversion pipelines may run at once. Demucs/RVC saturate the
# GPU on their own, so raising this usually just causes out-of-memory.
AVC_MAX_CONCURRENT_JOBS=1

# temp/<job_id>/ folders older than this many days are deleted at startup.
AVC_TEMP_RETENTION_DAYS=3

# Whisper model size for TTS-mode transcription:
# tiny/base/small/medium/large-v3 (bigger = more accurate, slower;
# downloaded automatically on first use)
AVC_WHISPER_MODEL=small
